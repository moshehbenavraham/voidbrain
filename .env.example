# Copy this file to `.env` and set the path to your local Obsidian dev vault.
# This file is safe to commit because it contains examples only. Never put API
# keys, bearer tokens, passwords, or authorization headers in tracked examples.
#
# Obsidian deploy setup:
# 1. Install the Obsidian desktop app for the operating system where you use the GUI.
#    - Windows users with WSL should install Obsidian for Windows.
#    - Linux desktop users should install Obsidian for Linux.
# 2. Create or open a disposable development vault in Obsidian.
#    A vault is just a local folder of Markdown files plus an `.obsidian/` config folder.
# 3. If the vault is on Windows, convert the path for WSL:
#    - Windows: C:\Users\<you>\Documents\Obsidian\Voidbrain Dev
#    - WSL:     /mnt/c/Users/<you>/Documents/Obsidian/Voidbrain Dev
# 4. Use a test vault while developing. Avoid pointing local automation at a real
#    personal vault until staged-write and review workflows are ready.
#
# Optional: OneDrive, Dropbox, and similar synced folders can work for a dev
# vault, but remember that generated notes and plugin state may sync to the
# cloud.

VOIDBRAIN_DEV_VAULT="/mnt/c/Users/<you>/Documents/Obsidian/Voidbrain Dev"

# Optional local provider defaults for manual setup in Obsidian:
# Settings -> Voidbrain -> Providers.
#
# These values are reference defaults for local development. The plugin does
# not currently auto-import provider profiles from `.env`; enter them in the
# settings UI. Use exact model IDs from:
#
#   curl -fsS http://127.0.0.1:11434/api/tags
#
# For localhost Ollama, choose "Local" in the UI. Do not choose
# "OpenAI-compatible" for `127.0.0.1:11434/v1` in the current UI.

VOIDBRAIN_PROVIDER_PROFILE_KIND="local"
VOIDBRAIN_PROVIDER_ID="ollama"
VOIDBRAIN_PROVIDER_DISPLAY_NAME="Ollama"
VOIDBRAIN_PROVIDER_ENDPOINT_URL="http://127.0.0.1:11434/v1"
VOIDBRAIN_CHAT_MODEL_ID="qwen2.5:7b"
VOIDBRAIN_EMBEDDING_MODEL_ID="nomic-embed-text:latest"

# Leave blank for local Ollama. Remote providers should be configured through
# the Obsidian settings UI secret boundary, not committed to repository files.
VOIDBRAIN_PROVIDER_RUNTIME_CREDENTIAL=""
